# =============================================================================
# PBX Call Centre – .env (place in project root; used by Node server and Vite)
# Copy to .env and fill in your values.
# =============================================================================

# --- Database (MySQL) – required for login and all features ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=pbx_callcentre

# --- API server (Node) ---
PORT=3001
# Comma-separated origins for CORS (add your LAN IP so other devices can open the app, e.g. http://10.50.7.181:5173)
CORS_ORIGIN=http://localhost:5173
SESSION_SECRET=change-this-to-a-random-secret-in-production

# --- Frontend (Vite) – base URL for API calls ---
VITE_API_URL=http://localhost:3001

# =============================================================================
# ASTERISK: Choose one setup
# =============================================================================
#
# CURRENT SETUP – Asterisk on another server (development / remote Asterisk)
# -------------------------------------------------------------------------
# - ARI and dialplan callbacks use the Asterisk server host.
# - Asterisk must be able to reach this app (curl) for InboundRoute, Recording, etc.
#   Set ASTERISK_APP_URL to this app’s URL as seen from Asterisk (e.g. your machine’s IP or hostname).
# - CDR recording playback will NOT work (app cannot read files on the other server).
#   Leave RECORDINGS_BASE_PATH empty.
#
# PRODUCTION – Same server for Asterisk and this app
# -------------------------------------------------------------------------
# - Use 127.0.0.1 or localhost for ARI and APP_URL.
# - Set RECORDINGS_BASE_PATH so the app can serve recording files from disk.
# =============================================================================

# --- Asterisk ARI (agent SIP, PJSIP status). App calls this to ring phones and list endpoints. ---
# Another server (current):
ASTERISK_ARI_URL=http://10.50.2.190:8088
# Same server (production): ASTERISK_ARI_URL=http://127.0.0.1:8088

ASTERISK_ARI_USER=myuser
ASTERISK_ARI_PASSWORD=your_ari_password_here

# --- URL Asterisk uses to call this app (curl). Must be reachable FROM the Asterisk server. ---
# Another server (current): use this machine’s IP/hostname so Asterisk can reach it, e.g.:
ASTERISK_APP_URL=http://YOUR_APP_SERVER_IP:3001/api/asterisk/
# Same server (production):
# ASTERISK_APP_URL=http://127.0.0.1:3001/api/asterisk/

# --- Recording paths (only used when app and Asterisk are on the SAME server) ---
# Another server (current): leave empty – app cannot read Asterisk’s recording files.
# RECORDINGS_BASE_PATH=
# Same server (production): path where Asterisk stores recordings; app streams from here for CDR playback.
# RECORDINGS_BASE_PATH=/var/spool/asterisk/monitor
# ASTERISK_RECORDING_PATH=/var/spool/asterisk/monitor

# --- Asterisk config sync (required for Sync to Asterisk to work) ---
# App POSTs config to this URL when you create/update agents, extensions, trunks.
# Run scripts/asterisk-config-receiver on the Asterisk server (see docs/ASTERISK-CONFIG-SYNC.md).
# If unset: "Sync to Asterisk" is skipped and Asterisk will not get new extensions (e.g. 6001, 6002).
ASTERISK_CONFIG_API_URL=http://10.50.2.190:9999
# ASTERISK_CONFIG_API_KEY=your-secret-key

# --- Asterisk logs (Super Admin dashboard) ---
# Same server (production): set ASTERISK_LOG_DIR so the app reads log files directly. No config-receiver needed for logs.
# ASTERISK_LOG_DIR=/var/log/asterisk
# Remote (current): leave ASTERISK_LOG_DIR unset; app uses ASTERISK_CONFIG_API_URL to fetch logs from config-receiver (see docs).

# --- Stasis app name (queue routing). Default: queue-dashboard ---
# ASTERISK_STASIS_APP=queue-dashboard

# --- Wallboard ---
# SLA threshold in seconds for service level calculation (default: 20)
# WALLBOARD_SLA_SECONDS=20

# --- Redis (optional, for wallboard real-time caching) ---
# When set, agent/queue state is cached in Redis for sub-second wallboard reads.
# If unset, wallboard reads directly from MySQL (still works, slightly higher latency).
# REDIS_URL=redis://localhost:6379

# --- Asterisk callback authentication (optional but recommended in production) ---
# When set, Asterisk HTTP callbacks must include this key as X-Asterisk-Key header.
# Add ?key=YOUR_KEY to curl URLs in the Asterisk dialplan.
# ASTERISK_CALLBACK_SECRET=your-secret-key-here

# --- Database pool size (default: 25) ---
# DB_POOL_SIZE=25
