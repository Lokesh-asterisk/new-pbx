# Database (MySQL) - required for real login (Option B)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=pbx_callcentre

# API server
PORT=3001
CORS_ORIGIN=http://localhost:5173
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Asterisk ARI (for agent SIP login: app originates call to extension, VM runs dialplan)
# App calls ARI on this URL to ring the agent's SIP phone. No /ari suffix.
ASTERISK_ARI_URL=http://10.50.2.190:8088
ASTERISK_ARI_USER=myuser
ASTERISK_ARI_PASSWORD=india@123

# Asterisk config sync: when Super Admin creates/updates agents or extensions, the app POSTs
# config to this URL so the Asterisk server can write agents.conf and pjsip_custom.conf.
# Run the config receiver on the Asterisk VM (see scripts/asterisk-config-receiver/ and docs/ASTERISK-CONFIG-SYNC.md).
# Leave unset to skip sync (no error).
# ASTERISK_CONFIG_API_URL=http://10.50.2.190:9999
# ASTERISK_CONFIG_API_KEY=your-secret-key
